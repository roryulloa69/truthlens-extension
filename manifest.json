{
  "manifest_version": 3,
  "name": "TruthLens",
  "version": "1.0.0",
  "description": "Detect AI content, deepfakes, and misinformation before you trust it.",
  "permissions": ["activeTab", "storage", "contextMenus"],
  "host_permissions": ["https://truthlens-api.royscompany.workers.dev/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "TruthLens"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
